# =================================================================
# 시스템 기본 설정
# SECRET_KEY 생성: python -c "import secrets; print(secrets.token_urlsafe(64))"
# 개발용 DB 초기화 RESET_DB_ON_STARTUP (주의: True면 서버 시작 시 MySQL 테이블을 초기화합니다)
# =================================================================
ENV=dev
DEBUG=True
TZ=Asia/Seoul
RESET_DB_ON_STARTUP=True

# MySQL (로컬)
DATABASE_URL=mysql+pymysql://root:1234@localhost:3307/meeting_assistant

# Railway MySQL
# DATABASE_URL=mysql://root:oIjMxEtuzSKVuAqKbFDuzJGdPqSRqGZc@nozomi.proxy.rlwy.net:30731/railway

# MongoDB
MONGODB_URL=mongodb://root:1234@localhost:27017/meeting_assistant?authSource=admin

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001

SECRET_KEY=여기에_직접_생성한_값_입력
ALGORITHM=HS256
REDIS_URL=redis://localhost:6379

# =================================================================
# AI 설정
# =================================================================
OPENAI_API_KEY=sk-xxxx
ANTHROPIC_API_KEY=sk-ant-xxxx
TAVILY_API_KEY=tvly-xxxx

# =================================================================
# Slack 연동
# OAuth 앱: https://api.slack.com/apps
# nginx 일 때 localhost callback -> https://localhost/api/v1/integrations/slack/callback
# =================================================================
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://localhost:8000/api/v1/integrations/slack/callback

# =================================================================
# JIRA 연동 (API Key 방식)
# nginx 일 때 localhost callback -> https://localhost/api/v1/integrations/jira/callback
# =================================================================
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:8000/api/v1/integrations/jira/callback

# =================================================================
# Google Calendar 연동
# OAuth 앱: https://console.cloud.google.com
# nginx 일 때 localhost callback -> https://localhost/api/v1/integrations/google/callback
# =================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/integrations/google/callback
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:8000/api/v1/users/oauth/google/callback

# =================================================================
# 프론트엔드 URL
# 로컬: http://localhost:5173
# Railway 배포 시: https://your-frontend.up.railway.app
# =================================================================
FRONTEND_URL=http://localhost:5173

# =================================================================
# 이메일 발송
# 관리자 회원가입 완료 메일 등 SMTP 기반 발송에 사용합니다.
# =================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Workb
SMTP_USE_TLS=True
ADMIN_SIGNUP_EMAIL_ENABLED=True
PASSWORD_RESET_TOKEN_MINUTES=30

# =================================================================
# AWS S3
# IAM 사용자에 s3:PutObject / s3:GetObject 권한이 있어야 합니다.
# Access Key는 절대 코드/Git에 커밋하지 마세요. (.gitignore의 .env 규칙 확인)
# =================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=
AWS_S3_PRESIGNED_EXPIRES=3600

# =================================================================
# Railway 배포 시 변경 필요한 항목
# DATABASE_URL    → ${{MySQL.MYSQL_URL}} (Railway MySQL 자동 주입)
# GOOGLE_REDIRECT_URI → https://your-app.up.railway.app/api/v1/integrations/google/callback
# GOOGLE_LOGIN_REDIRECT_URI → https://your-app.up.railway.app/api/v1/users/oauth/google/callback
# SLACK_REDIRECT_URI  → https://your-app.up.railway.app/api/v1/integrations/slack/callback
# KAKAO_LOGIN_REDIRECT_URI → https://your-app.up.railway.app/api/v1/users/oauth/kakao/callback
# FRONTEND_URL    → https://your-frontend.up.railway.app (또는 로컬 테스트 시 http://localhost:5173)
# DEBUG           → False
# ENV             → production
# =================================================================


FRONTEND_URL=http://localhost:5173

GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:8000/api/v1/users/oauth/google/callback

KAKAO_REST_API_KEY=...
KAKAO_CLIENT_SECRET=...
KAKAO_LOGIN_REDIRECT_URI=http://localhost:8000/api/v1/users/oauth/kakao/callback